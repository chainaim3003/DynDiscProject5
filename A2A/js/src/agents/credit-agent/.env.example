# Jupiter Credit Sub-Agent — env template
# Copy to .env (same directory) and adjust if needed.

# Port the agent listens on. CreditProvider in real-mode connects to this.
PORT=7071

# Filename inside DEMO-DATA/credit/ that the agent serves at POST /consult.
# To swap fixtures, change this value and restart the agent.
CREDIT_FIXTURE=edgar-companyfacts-PHILLIPS-VAN-HEUSEN.json