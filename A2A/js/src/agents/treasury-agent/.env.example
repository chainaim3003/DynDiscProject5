# Treasury Agent — Jupiter CFO (port 7070)

# ── Gemini API (only needed if treasury makes LLM calls; today it does not) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model selection per tier ────────────────────────────────────────────────
# Treasury (and any future routing / sub-agent advisories) use Flash tier.
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Cost-control override (leave blank for normal tier-based selection) ─────
GEMINI_FORCE_MODEL=

# ── Safety ceilings ─────────────────────────────────────────────────────────
PER_NEGOTIATION_TOKEN_CEILING=20000
GEMINI_MAX_RETRIES=3

# ── Port ────────────────────────────────────────────────────────────────────
PORT=7070