# Buyer Agent — Tommy Hilfiger (port 9090)

# ── Gemini API (required) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model selection per tier ────────────────────────────────────────────────
# Buyer's main negotiation decision uses Pro tier (rationality matters).
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Cost-control override (leave blank for normal tier-based selection) ─────
# For dev runs where you want everything on the cheapest model:
#   GEMINI_FORCE_MODEL=gemini-2.5-flash-lite
GEMINI_FORCE_MODEL=

# ── Safety ceilings ─────────────────────────────────────────────────────────
PER_NEGOTIATION_TOKEN_CEILING=20000
GEMINI_MAX_RETRIES=3

# ── Port ────────────────────────────────────────────────────────────────────
PORT=9090