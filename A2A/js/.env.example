# ── Gemini API (required) ───────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey  (starts with AIza...)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model selection per tier (defaults shown) ───────────────────────────────
# Pro    = used for seller + buyer main negotiation decisions
# Flash  = used for treasury and any future routing / sub-agent advisories
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Cost-control override (leave blank for normal tier-based selection) ─────
# If set, ALL LLM calls use this model regardless of tier. Useful for dev runs
# where you want everything on the cheapest model. Example:
#   GEMINI_FORCE_MODEL=gemini-2.5-flash-lite
GEMINI_FORCE_MODEL=

# ── Per-negotiation token ceiling (safety) ──────────────────────────────────
PER_NEGOTIATION_TOKEN_CEILING=20000

# ── Retry behavior on 429s ──────────────────────────────────────────────────
GEMINI_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# ITERATION 1 — IDENTITY + COMPLIANCE
# ─────────────────────────────────────────────────────────────────────────────

# Mode selection for the CredentialProvider. Two valid values:
#   plain  — agent card + real GLEIF check. No KERI/vLEI required. (default)
#   vlei   — all of plain PLUS KERI delegation chain via legentvLEI port 4000.
# Anything else logs a warning and falls back to plain.
CREDENTIAL_MODE=plain

# ── Agent card directories ──────────────────────────────────────────────────
# live-agent-cards/  customer-onboarded cards (gitignored)
# demo-agent-cards/  source-controlled demo cards
# Override if you want a non-default location.
# LIVE_AGENT_CARDS_DIR=./live-agent-cards
# DEMO_AGENT_CARDS_DIR=./demo-agent-cards

# ── GLEIF API (real, no mocks) ──────────────────────────────────────────────
GLEIF_API_URL=https://api.gleif.org/api/v1
GLEIF_TIMEOUT_MS=8000

# Re-check LEI status on EVERY negotiation start? (default true)
# Set false to use the cache only (cheaper, less defensive).
GLEIF_RECHECK_AT_NEGOTIATION=true

# Cache TTL in hours (default 24)
GLEIF_CACHE_TTL_HOURS=24

# Optional sanctions list — ISO 3166-1 alpha-2 codes, comma-separated.
# When set, an LEI registered in any listed country fails compliance.
# SANCTIONED_COUNTRIES=KP,IR,SY,RU

# ── Onboarding API server port ──────────────────────────────────────────────
ONBOARDING_PORT=6060

# ── Audit Query (GraphQL) server ─────────────────────────────────────────────
# Read by src/api/graphql/index.ts at startup. Defaults preserve prior behavior
# (127.0.0.1:5000). Override here if 5000 is taken on your machine.
AUDIT_QUERY_HOST=127.0.0.1
AUDIT_QUERY_PORT=5000

# ──────────────────────────────────────────────────────────────────────────────────
# ITERATION 2 — MESSAGE SIGNING
# ─────────────────────────────────────────────────────────────────────────────────

# Mode for the per-message envelope between seller and buyer.
#   plain  (default)  — sha256 hash, tamper-evidence + replay protection, NO crypto identity.
#   vlei              — KERI signatures (Phase 2, iteration 14). Throws today.
SIGNING_MODE=plain

# Reject messages older than this (default 5 minutes).
MAX_MESSAGE_AGE_MS=300000

# Reject messages claiming to be more than this far in the future (default 30s).
MAX_FUTURE_SKEW_MS=30000

# ─────────────────────────────────────────────────────────────────────────────
# ITERATION 15 — WHATSAPP NOTIFICATIONS (Meta Cloud API, direct, no BSP)
# ─────────────────────────────────────────────────────────────────────────────
# Setup steps for these five values are in SETUP-WHATSAPP.md (companion file).
#
# 1. META_TEST_PHONE_ID — Phone Number ID shown on the Meta Developer App
#    Dashboard at WhatsApp → API Setup. This is Meta's TEST sender number;
#    you do not buy or register a phone for the sender side in test mode.
META_TEST_PHONE_ID=
#
# 2. META_WABA_ID — the WhatsApp Business Account ID auto-created for you
#    when you added the WhatsApp product to your Meta App.
META_WABA_ID=
#
# 3. META_SYSTEM_USER_TOKEN — long-lived token from Meta Business Suite →
#    Users → System Users. NOT the 23-hour temp token from the dev console.
#    Permissions: whatsapp_business_messaging + whatsapp_business_management.
META_SYSTEM_USER_TOKEN=
#
# 4. BUYER_PERSONAL_WHATSAPP_E164 — the personal WhatsApp number that should
#    receive buyer-side agent events. E.164 format (+, country, number).
#    MUST be added to the Meta test number's recipient allowlist (Phase A5).
BUYER_PERSONAL_WHATSAPP_E164=
#
# 5. SELLER_PERSONAL_WHATSAPP_E164 — same, for seller-side.
SELLER_PERSONAL_WHATSAPP_E164=
#
# Optional: override the path to the routing YAML (default: ./config/notification-routing.yaml)
# NOTIFICATION_ROUTING_CONFIG=